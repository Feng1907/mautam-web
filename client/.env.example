# Để trống khi dev local (Vite proxy tự xử lý)
# Điền URL Render khi deploy production
VITE_API_URL=

# Firebase — lấy từ Firebase Console > Project Settings > Your apps
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Sentry — lấy DSN từ sentry.io > Project > Settings > Client Keys
# Chỉ hoạt động trên production build, để trống khi dev local
VITE_SENTRY_DSN=

# URL production của site (dùng cho SEO og:url)
VITE_SITE_URL=https://mautam.net
