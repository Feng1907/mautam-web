# ── Server ────────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=production

# ── Database ──────────────────────────────────────────────────────────────────
# Local dev:      mongodb://localhost:27017/mautam
# MongoDB Atlas:  mongodb+srv://<user>:<pass>@cluster0.xxxxx.mongodb.net/mautam
MONGODB_URI=mongodb://localhost:27017/mautam

# ── Auth ──────────────────────────────────────────────────────────────────────
# Tạo chuỗi ngẫu nhiên mạnh: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your_strong_secret_here

# ── CORS ──────────────────────────────────────────────────────────────────────
# Nhiều origin cách nhau dấu phẩy (dev + prod)
# VD: http://localhost:5173,https://mautam.vercel.app
CLIENT_URL=http://localhost:5173

# ── Email (Gmail App Password) ────────────────────────────────────────────────
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_16_char_app_password
